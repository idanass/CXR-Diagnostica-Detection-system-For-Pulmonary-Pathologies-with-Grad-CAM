{
  "__inputs": [],
  "__requires": [],
  "title": "CXR-Diagnostica Monitoring",
  "uid": "cxr-monitoring",
  "version": 1,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "http_requests_total{handler=\"/predict\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 2,
      "title": "Total Reports Generated",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "http_requests_total{handler=\"/report\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "id": 3,
      "title": "Successful Requests",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "http_requests_total{status=\"2xx\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "id": 4,
      "title": "Failed Requests",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "http_requests_total{status=\"4xx\"}", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 5,
      "title": "Request Rate (per second)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "rate(http_requests_total[5m])", "legendFormat": "{{handler}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "title": "Inference Duration (seconds)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "http_request_duration_seconds_sum{handler=\"/predict\"}", "legendFormat": "predict duration", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7,
      "title": "Requests by Endpoint",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "http_requests_total", "legendFormat": "{{handler}}", "refId": "A"}],
      "options": {"xField": "handler"}
    },
    {
      "id": 8,
      "title": "API Response Size (bytes)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "http_response_size_bytes_sum", "legendFormat": "{{handler}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s"
}